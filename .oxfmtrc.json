{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "semi": false,
  "singleQuote": true,
  "trailingComma": "es5",
  "arrowParens": "always",
  "printWidth": 120,
  "sortPackageJson": false,
  "ignorePatterns": [
    "*.model.ts",
    "src/model",
    "db/migrations",
    "*.json",
    "tests/**/*",
    "src/server-extension",
    "src/types",
    "lib/**/*",
    "*.yaml",
    "*.yml",
    "*.md",
    ".github"
  ]
}
