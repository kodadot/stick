{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "import",
    "unicorn"
  ],
  "categories": {
    "correctness": "off"
  },
  "env": {
    "builtin": true
  },
  "ignorePatterns": [
    "tests/**/*",
    "src/model",
    "src/server-extension",
    "src/types",
    "lib/**/*"
  ],
  "rules": {}
}