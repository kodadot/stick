{
  "name": "@kodadot1/stick",
  "version": "0.2.0",
  "description": "AssetHub block indexer and graphql server",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf lib && tsc",
    "test": "vitest run",
    "update": "npx npm-check-updates --filter /subsquid/ --upgrade && npm i -f",
    "db:migrate": "npx squid-typeorm-migration apply",
    "processor:start": "node lib/processor.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "query-node:start": "squid-graphql-server --subscriptions --max-response-size 10000 --dumb-cache in-memory --dumb-cache-ttl 1000 --dumb-cache-size 100 --dumb-cache-max-age 1000"
  },
  "dependencies": {
    "@kodadot1/hyperdata": "^0.0.2-rc.1",
    "@kodadot1/metasquid": "^0.3.1-rc.0",
    "@kodadot1/minipfs": "^0.5.1-rc.2",
    "@subsquid/archive-registry": "3.3.2",
    "@subsquid/graphql-server": "4.12.0",
    "@subsquid/ss58": "2.0.2",
    "@subsquid/substrate-processor": "8.8.1",
    "@subsquid/typeorm-migration": "1.3.1",
    "@subsquid/typeorm-store": "1.9.1",
    "dotenv": "^17.4.2",
    "md5": "^2.3.0",
    "nanoid": "^3.3.15",
    "pg": "^8.22.0",
    "type-graphql": "^1.2.0-rc.1",
    "typeorm": "0.3.20"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@subsquid/substrate-metadata-explorer": "3.2.0",
    "@subsquid/substrate-typegen": "8.1.0",
    "@subsquid/typeorm-codegen": "2.2.0",
    "@types/md5": "^2.3.6",
    "@types/node": "26.0.0",
    "@types/pg": "^8.20.0",
    "eslint": "^10.5.0",
    "eslint-config-unjs": "^0.6.2",
    "oxfmt": "^0.55.0",
    "oxlint": "^1.70.0",
    "prettier": "^3.8.4",
    "typescript": "~6.0.3",
    "vitest": "^4.1.9"
  }
}
